# Backend loads environment from the project root `.env` first (see backend/app/config.py).
# Copy the repository root `.env.example` to `../.env` and adjust values there.
#
# Optional: override below for backend-only local experiments (unusual).

FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=

# Resolved by BaseConfig: DATABASE_URL, or DEV_DATABASE_URL (dev), or PROD_DATABASE_URL (prod)
DATABASE_URL=postgresql://phishing_user:phishing_password@localhost:5432/phishing_db
DEV_DATABASE_URL=sqlite:///app.db
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
